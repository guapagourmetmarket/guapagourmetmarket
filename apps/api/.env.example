DATABASE_URL=postgresql://guapa:guapa@localhost:5432/guapa_gourmet
JWT_SECRET=cambia-este-valor-en-produccion
PORT=3000
WEB_ORIGIN=http://localhost:5173
# Para entrar desde el celular u otro computador en la misma red WiFi, agrega
# la IP local separada por coma, ej: WEB_ORIGIN=http://localhost:5173,http://192.168.1.50:5173

# Opcionales — solo necesarios en producción contra un Postgres administrado
# DATABASE_SSL=true
# DATABASE_POOL_MAX=10

# Cloudinary: almacenamiento permanente de fotos de producto (cloudinary.com,
# plan gratis, sin tarjeta). Se obtienen en el dashboard, sección "API Keys".
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
